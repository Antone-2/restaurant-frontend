# Environment Variables for The Quill Restaurant - PRODUCTION
# IMPORTANT: Replace 'your-backend' with your actual Render backend name
# Example: if your backend is at https://the-quill.onrender.com, use that URL
# NOTE: Do NOT include /api at the end - the code adds it automatically

# ============================================
# REQUIRED: Backend API URL
# ============================================
# Replace with your actual Render backend URL
# Get this from your Render dashboard after deploying the backend
# IMPORTANT: Do NOT include /api suffix here
VITE_API_URL=https://restaurant-backend-30ab.onrender.com

# ============================================
# OPTIONAL: WebSocket URL for real-time updates
# ============================================
VITE_WS_URL=wss://restaurant-backend-30ab.onrender.com

# ============================================
# OPTIONAL: App Configuration
# ============================================
VITE_APP_NAME=The Quill
VITE_ENABLE_ANALYTICS=true
