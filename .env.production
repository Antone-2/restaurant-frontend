# Production Environment Variables for The Quill Restaurant App
# IMPORTANT: Replace the placeholder values with your actual production URLs

# Required: Backend API URL (replace with your Render.com backend URL)
# Example: VITE_API_URL=https://the-quill-backend.onrender.com
VITE_API_URL=https://your-backend.onrender.com

# Optional: WebSocket URL (if different from API URL)
# Example: VITE_WS_URL=wss://the-quill-backend.onrender.com
# VITE_WS_URL=https://your-backend.onrender.com

# Optional: App name
# VITE_APP_NAME=The Quill

# Optional: Enable analytics (set to 'true' to enable)
# VITE_ENABLE_ANALYTICS=false
