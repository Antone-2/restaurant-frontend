# Environment Variables for The Quill Restaurant - PRODUCTION
# These are used when deploying to Vercel

# ============================================
# REQUIRED: Backend API URL
# ============================================
# Your Render backend URL (replace with your actual Render URL)
VITE_API_URL=https://your-backend.onrender.com

# ============================================
# OPTIONAL: WebSocket URL for real-time updates
# ============================================
# For production: wss://your-backend.onrender.com
# If not set, will default to VITE_API_URL
VITE_WS_URL=wss://your-backend.onrender.com

# ============================================
# OPTIONAL: App Configuration
# ============================================
VITE_APP_NAME=The Quill
VITE_ENABLE_ANALYTICS=true
