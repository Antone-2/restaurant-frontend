# Environment Variables for The Quill Restaurant App
# Copy this file to .env and fill in your values

# Required: Backend API URL
# For local development: http://localhost:3001
# For production: https://your-backend.onrender.com
VITE_API_URL=http://localhost:3001

# Optional: WebSocket URL (defaults to VITE_API_URL if not set)
# For production: wss://your-backend.onrender.com
# VITE_WS_URL=http://localhost:3001

# Optional: App name
# VITE_APP_NAME=The Quill

# Optional: Enable analytics
# VITE_ENABLE_ANALYTICS=false
